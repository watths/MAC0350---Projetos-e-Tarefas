
* {
    box-sizing: border-box;
}

body {
    background-color: black;
    justify-content: center;
    margin: 30px;
}

header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    color: white;
    background-color: black;
    width: 100%;
    padding: 0 20px;
    box-sizing: border-box;
    margin: 10px;
    height: 10vh;
}

#icone {
    width: 10vw;
    height: auto;
}


#container {
    display: flex;
    align-items: flex-start;
}

#sidebar {
    display: flex;
    width: 14vw;
    color: white;
    justify-content: center;
}

#emails{
    display: flex;
    border-radius: 20px;
    width: 86vw;
    background-color: #2a2a2a;
    color: white;
}

#conteudo {
    padding: 3vh 2vw;
    width: 100%;
}

nav {
    padding: 2vh 1vw;
    border-radius: 20px;
    background-color: #2a2a2a;
    display: flex;
    flex-direction: column;
    gap: 2vh;
    text-align: center;
    align-items: center;
}

.botaonav {
    width: 100%;
    display: block;
    padding: 1vh 1vw;
    height: 5vh;
    text-decoration: none;
    background-color: #2a2a2a;
    color: white;
    border: none;
    font-size: 14px;
}

.botaonav:hover {
    background-color: gray;
    border-radius: 5px;
    cursor: pointer;
}

#busca {
    width: 20vw;
    font-size: 16px;
    height: 5vh;
}

#titulo {
    width: 30%;
    font-size: 16px;
    height: 5vh;
}

#destino {
    width: 20%;
    font-size: 16px;
    height: 5vh;
}

#mensagem {
    align-items: center;
    width: 100%;
    height: 40vh;
    font-size: 16px;
}


#botao {
    height: 5vh;
    width: 6vw;
    font-size: 16px;
    cursor: pointer;
}

ul.custom-list {
    list-style: none;
    padding-left: 0;
    margin-top: 1rem;
}

ul.custom-list li {
    background-color: #2a2a2a;
    margin-bottom: 0.5rem;
    padding: 0.6rem 1rem;
    border-radius: 8px;
    border-left: 4px solid gray;
    color: white;
    transition: background-color 0.3s ease;
    width: 100%;
}

ul.custom-list li:hover {
    background-color: gray;
}

#escrever_email {
    gap: 2vh;
    display: flex;
    flex-direction: column;
    width: 100%;
}

#botaoenviar {
    height: 5vh;
    width: 6vw;
    font-size: 16px;
    cursor: pointer;
    align-self: flex-end;
}
